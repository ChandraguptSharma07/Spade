<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SPADE Report — {{ prov.uniprot_id }}</title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; max-width: 960px; margin: 0 auto; padding: 2rem; color: #222; }
    h1, h2 { color: #1a1a2e; }
    h1 { border-bottom: 2px solid #e74c3c; padding-bottom: 0.4rem; }
    .meta-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin: 1rem 0 2rem; }
    .meta-card { background: #f8f9fa; border-radius: 6px; padding: 0.8rem 1rem; border-left: 4px solid #3498db; }
    .meta-card .label { font-size: 0.75rem; color: #666; text-transform: uppercase; letter-spacing: 0.05em; }
    .meta-card .value { font-size: 1.4rem; font-weight: 600; color: #1a1a2e; }
    .confidence-high { color: #27ae60; }
    .confidence-medium { color: #f39c12; }
    .confidence-low { color: #e74c3c; }
    table { width: 100%; border-collapse: collapse; margin: 1rem 0; }
    th { background: #1a1a2e; color: white; padding: 0.5rem 0.8rem; text-align: left; font-size: 0.85rem; }
    td { padding: 0.45rem 0.8rem; border-bottom: 1px solid #eee; font-size: 0.9rem; }
    tr:hover td { background: #f0f4ff; }
    .smiles { font-family: monospace; background: #f0f4ff; padding: 0.3rem 0.6rem; border-radius: 4px; font-size: 0.85rem; }
    .warn { background: #fff3cd; border: 1px solid #ffc107; border-radius: 4px; padding: 0.6rem 1rem; margin: 1rem 0; }
    pre.prov { background: #1a1a2e; color: #a8d8a8; padding: 1rem; border-radius: 6px; overflow-x: auto; font-size: 0.78rem; max-height: 300px; }
    .run-id { font-family: monospace; font-size: 0.75rem; color: #888; }
    footer { margin-top: 3rem; border-top: 1px solid #eee; padding-top: 1rem; font-size: 0.8rem; color: #888; }
  </style>
</head>
<body>

<h1>SPADE Docking Report</h1>
<p class="run-id">Run ID: {{ prov.run_id }} &nbsp;|&nbsp; {{ prov.timestamp }}</p>

<!-- Key metrics -->
<div class="meta-grid">
  <div class="meta-card">
    <div class="label">Target</div>
    <div class="value">{{ prov.uniprot_id if prov.uniprot_id else "—" }}</div>
  </div>
  <div class="meta-card">
    <div class="label">Top cluster score</div>
    <div class="value">{{ "%.2f"|format(prov.top_cluster_score) }} kcal/mol</div>
  </div>
  <div class="meta-card">
    <div class="label">Site confidence</div>
    <div class="value confidence-{{ prov.site_confidence }}">{{ prov.site_confidence | upper }}</div>
  </div>
  <div class="meta-card">
    <div class="label">Conformers</div>
    <div class="value">{{ prov.n_conformers_generated }}</div>
  </div>
  <div class="meta-card">
    <div class="label">Total poses</div>
    <div class="value">{{ prov.n_total_poses }}</div>
  </div>
  <div class="meta-card">
    <div class="label">Clusters</div>
    <div class="value">{{ prov.n_clusters }}</div>
  </div>
</div>

{% if prov.inter_domain_pae_warning %}
<div class="warn">
  <strong>PAE Warning:</strong> Inter-domain PAE values detected — flexibility graph restricted to pocket-local region (12 Å cutoff).
</div>
{% endif %}

<!-- Ligand -->
<h2>Ligand</h2>
<p>SMILES: <span class="smiles">{{ prov.ligand_smiles }}</span></p>
<p>Variants prepared: <strong>{{ prov.n_ligand_variants }}</strong></p>

<!-- Per-conformer table -->
{% if prov.conformer_summaries %}
<h2>Per-conformer Results</h2>
<table>
  <thead>
    <tr>
      <th>#</th>
      <th>Cα RMSD from ref (Å)</th>
      <th>Poses</th>
      <th>Best score (kcal/mol)</th>
      <th>Dock time (s)</th>
    </tr>
  </thead>
  <tbody>
    {% for s in prov.conformer_summaries %}
    <tr>
      <td>{{ s.conformer_index }}</td>
      <td>{{ "%.3f"|format(s.ca_rmsd_from_ref) }}</td>
      <td>{{ s.n_poses }}</td>
      <td>{{ "%.2f"|format(s.best_score_kcal_mol) }}</td>
      <td>{{ "%.1f"|format(s.docking_time_seconds) }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endif %}

<!-- pLDDT summary -->
<h2>Structure Quality</h2>
<p>AlphaFold version: <strong>{{ prov.af_version if prov.af_version else "unknown" }}</strong> &nbsp;|&nbsp;
   Residues: <strong>{{ prov.n_residues }}</strong> &nbsp;|&nbsp;
   Mean pLDDT: <strong>{{ "%.1f"|format(prov.plddt_mean) }}</strong> ± {{ "%.1f"|format(prov.plddt_std) }}</p>

<!-- Provenance JSON -->
<h2>Full Provenance</h2>
<script type="application/json" id="spade-provenance">
{{ prov_json }}
</script>
<pre class="prov">{{ prov_json }}</pre>

<footer>
  Generated by SPADE v{{ prov.spade_version }} &nbsp;|&nbsp;
  <a href="https://github.com/ChandraguptSharma07/Spade" rel="noopener">GitHub</a>
</footer>

</body>
</html>
